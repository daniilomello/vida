{
  "name": "@vida/backend",
  "private": true,
  "version": "2.0.2",
  "type": "module",
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs'),path=require('path'),cp=require('child_process');const s=path.join(process.cwd(),'scripts/patch-serverless-offline.mjs');if(!fs.existsSync(s))process.exit(0);const r=cp.spawnSync(process.execPath,[s],{stdio:'inherit'});process.exit(r.status??1);\"",
    "dev": "serverless offline start",
    "deploy:dev": "serverless deploy --stage dev",
    "check": "biome check .",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1038.0",
    "@aws-sdk/client-dynamodb": "^3.1038.0",
    "@aws-sdk/client-ses": "^3.1038.0",
    "@aws-sdk/lib-dynamodb": "^3.1038.0",
    "@middy/core": "^7.4.0",
    "@middy/http-cors": "^7.4.0",
    "@middy/http-error-handler": "^7.4.0",
    "@middy/http-json-body-parser": "^7.4.0",
    "aws-jwt-verify": "^4.0.1",
    "http-errors": "^2.0.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.149",
    "@types/http-errors": "^2.0.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.0",
    "jest": "^30.3.0",
    "serverless": "^4.34.0",
    "serverless-offline": "^14.5.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
