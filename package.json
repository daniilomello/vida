{
  "name": "vida",
  "private": true,
  "version": "2.0.1",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,yellow \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "check": "biome check .",
    "check:fix": "biome check --apply .",
    "release": "node scripts/release.mjs release",
    "release:pr": "node scripts/release.mjs pr",
    "release:tag": "node scripts/release.mjs tag",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,css}": "biome check --write --no-errors-on-unmatched"
  },
  "overrides": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "@biomejs/biome": "^2.4.13",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^6.0.3"
  }
}
